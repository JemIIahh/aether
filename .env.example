PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://aether:password@localhost:5432/aether
DB_PASSWORD=changeme

# Auth (optional — game runs in guest-only mode without these)
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Client-side (Vite injects these at build time)
VITE_PRIVY_APP_ID=your-privy-app-id
VITE_PRIVY_CLIENT_ID=your-privy-client-id

# 0G Chain — bribes & native balance verification
# Testnet (Galileo): 16602 / Mainnet: 16661
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_CHAIN_ID=16602
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Treasury (optional — falls back to mock token system if unset)
TREASURY_ADDRESS=0x...your-treasury-public-address
VITE_TREASURY_ADDRESS=0x...same-address

# 0G Storage — agent memory, arena replays, composer recipes
# Disabled if DEPLOYER_PRIVATE_KEY is not set above.
OG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute — The Aetherist runs on 0G's decentralized inference network.
# Set DEPLOYER_PRIVATE_KEY to a wallet on 0G testnet/mainnet that has been:
#   1. Funded with native 0G tokens (faucet.0g.ai for testnet)
#   2. Used to fund the broker ledger via `npm run aetherist:fund`
# The agent runner uses this wallet to sign inference request headers and
# pulls cost from the broker ledger. NEVER commit a real private key.
DEPLOYER_PRIVATE_KEY=0x...
# Optional: filter providers by model substring (e.g. "qwen", "llama")
OG_COMPUTE_MODEL=
