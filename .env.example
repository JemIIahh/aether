PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://aether:password@localhost:5432/aether
DB_PASSWORD=changeme

# Auth (optional — game runs in guest-only mode without these)
JWT_SECRET=change-this-to-a-random-32-char-string-in-production
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=your-privy-app-secret

# Client-side (Vite injects these at build time)
VITE_PRIVY_APP_ID=your-privy-app-id
VITE_PRIVY_CLIENT_ID=your-privy-client-id

# 0G Chain — bribes & native balance verification
# Testnet (Galileo): 16602 / Mainnet: 16661
OG_CHAIN_ID=16602
OG_RPC_URL=https://evmrpc-testnet.0g.ai
VITE_OG_CHAIN_ID=16602
VITE_OG_RPC_URL=https://evmrpc-testnet.0g.ai

# Treasury (optional — falls back to mock token system if unset)
TREASURY_ADDRESS=0x...your-treasury-public-address
VITE_TREASURY_ADDRESS=0x...same-address

# 0G Compute — agent inference broker
# Phase 3: wire The Aetherist's reasoning loop through 0G Compute
OG_COMPUTE_BROKER_URL=https://broker.testnet.0g.ai
OG_COMPUTE_MODEL=
OG_COMPUTE_API_KEY=
