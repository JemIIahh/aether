{
  "name": "aether",
  "version": "0.1.0",
  "description": "Aether — an AI game master (The Aetherist) builds a 3D multiplayer arena live around players, on 0G Chain",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --env-file=.env src/server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production node --env-file=.env src/server/index.js",
    "test": "node src/server/test.js",
    "world": "node --env-file=.env src/server/index.js",
    "aetherist": "node --env-file=.env agent-runner-0g.js",
    "aetherist:fund": "node --env-file=.env scripts/og-fund-ledger.js",
    "bribe:e2e": "node --env-file=.env scripts/og-bribe-e2e.js"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.8",
    "@colyseus/ws-transport": "^0.15.0",
    "@privy-io/react-auth": "^3.13.1",
    "@privy-io/server-auth": "^1.32.5",
    "buffer": "^6.0.3",
    "cannon-es": "^0.20.0",
    "colyseus": "^0.15.0",
    "colyseus.js": "^0.15.28",
    "cors": "^2.8.5",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.160.0",
    "viem": "^2.45.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^8.2.0",
    "vite": "^5.0.0"
  }
}
